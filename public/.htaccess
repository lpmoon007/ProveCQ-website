# provecq.com — Apache/Plesk config for the static export.
# Shipped from public/ → copied into out/ at build → rsync'd to httpdocs.

Options -MultiViews -Indexes
# Don't let Apache 301 /for-eos → /for-eos/ (those section hubs are a .html file
# AND a folder of child pages; the folder has no index, so the slash 404s).
DirectorySlash Off

RewriteEngine On

# ---------------------------------------------------------------------------
# 1. FPO → Prove 301 migration (must run before the generic rules below).
#    Mirror of prototype/Sitemap-Redirects.dc.html.
# ---------------------------------------------------------------------------
RewriteRule ^eos/?$                          /for-eos [R=301,L]
RewriteRule ^eos/(.*)$                        /for-eos/$1 [R=301,L]
RewriteRule ^free-tools/hidden-gem/?$         /free-tools/hidden-gem-identifier [R=301,L]
RewriteRule ^services/?$                      /work-with-us [R=301,L]
RewriteRule ^get-to-green/?$                  /free-tools/get-to-green [R=301,L]
RewriteRule ^get-to-green-app/?$              /free-tools/get-to-green [R=301,L]
RewriteRule ^playbook/?$                      /free-tools [R=301,L]
RewriteRule ^team/?$                          /about [R=301,L]
RewriteRule ^lifecycle/?$                     /guides [R=301,L]
RewriteRule ^resources/?$                     /guides [R=301,L]
RewriteRule ^(what-is-a-fractional-chro|what-does-a-cpo-do|cost|vs-consultant|vs-peo|7-signs|turnover|culture|due-diligence|onboarding|for-pe|hr-systems)/?$ /guides [R=301,L]

# ---------------------------------------------------------------------------
# 2. Canonicalize: strip a trailing slash when a matching page exists, so
#    /for-eos/ and /guides/ resolve to the clean /for-eos, /guides (no dup).
# ---------------------------------------------------------------------------
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/$ /$1 [R=301,L]

# ---------------------------------------------------------------------------
# 3. Serve the prerendered .html extensionless — even when a same-named
#    directory exists (this is what fixes the hub 404s).
# ---------------------------------------------------------------------------
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Custom 404 (Next emits out/404.html)
ErrorDocument 404 /404.html

# ---------------------------------------------------------------------------
# 4. Compression + caching for static assets (safe no-ops if a module is off).
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    text/javascript application/javascript application/json application/xml image/svg+xml
  # Also match by extension — Next serves .js as text/javascript on some Apache
  # builds, which the type list above can miss.
  <FilesMatch "\.(js|mjs|css|svg)$">
    SetOutputFilter DEFLATE
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  # Next's assets under /_next/static are content-hashed → cache hard.
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType image/jpeg               "access plus 30 days"
  ExpiresByType image/png                "access plus 30 days"
  ExpiresByType image/svg+xml            "access plus 30 days"
  ExpiresByType image/x-icon             "access plus 30 days"
  # HTML stays fresh so deploys show up immediately.
  ExpiresByType text/html                "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Force HTTPS for a year (site + www are HTTPS with a valid cert).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
